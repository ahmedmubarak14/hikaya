# =============================================================================
# Hikaya — Root environment example
# Copy to .env and fill in for local development. Per-app envs live under apps/*.
# =============================================================================

NODE_ENV=development

# --- Database -----------------------------------------------------------------
DATABASE_URL="postgresql://hikaya:hikaya@localhost:5432/hikaya?schema=public"

# --- Redis (sessions, pub/sub, cache) -----------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Auth ---------------------------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- OAuth providers ----------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# --- Payments (Moyasar) -------------------------------------------------------
MOYASAR_PUBLISHABLE_KEY=""
MOYASAR_SECRET_KEY=""

# --- Media (Cloudinary, Cloudflare Stream) ------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDFLARE_STREAM_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@hikaya.sa"

# --- Search (Algolia) ---------------------------------------------------------
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_API_KEY=""
ALGOLIA_SEARCH_API_KEY=""

# --- Observability ------------------------------------------------------------
SENTRY_DSN=""
POSTHOG_API_KEY=""
