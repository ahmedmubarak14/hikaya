{
  "name": "@hikaya/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema and generated client for Hikaya. The single source of truth for the data model.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "echo \"@hikaya/database has only schema + seed; no .ts source to lint\"",
    "typecheck": "tsc --noEmit",
    "build": "prisma generate",
    "clean": "rm -rf .turbo dist node_modules/.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@hikaya/config": "workspace:*",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
